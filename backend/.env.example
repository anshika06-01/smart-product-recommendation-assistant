# Copy this file to .env and fill in the values. Do not commit .env.

# Required: create an API key in Google AI Studio.
GOOGLE_API_KEY=replace_with_your_google_ai_api_key

# Run list_models.py after setup if you want to select a different model.
LLM_MODEL=gemini-1.5-flash-latest
LLM_TEMPERATURE=0.3

# Required: absolute path to your real catalogue. Forward slashes work on Windows.
PRODUCT_CSV_PATH=C:/path/to/ecommerce_products_killer.csv

# Conversation memory window.
MAX_HISTORY_MESSAGES=10

# Optional application logging flag.
DEBUG=false
